# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/food-waste-management
MONGODB_ATLAS_URI=your_mongodb_atlas_uri_here

# Server Configuration
PORT=5003
NODE_ENV=development

# JWT Configuration
